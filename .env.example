S3MS_PORT=8080
S3MS_STORAGE_PROVIDER=filesystem
S3MS_FILESYSTEM_ROOT=/var/lib/s3-message-service
S3MS_OBJECT_NAMESPACE=
S3MS_HTTP_ADDR=0.0.0.0:8080
S3MS_MAX_PAGE_SIZE=100
S3MS_READ_LOOKBACK_MINUTES=43200

# Backblaze B2 settings, required only when S3MS_STORAGE_PROVIDER=b2.
# B2_BUCKET_NAME=
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_S3_ENDPOINT=
# B2_S3_REGION=
# B2_FORCE_PATH_STYLE=true
